{
  "version": "1",
  "ops": [
    {
      "op": "add-entity",
      "fields": [
        "id",
        "entity"
      ],
      "summary": "Create an entity; its components are schema-validated and its parent (if any) must already exist."
    },
    {
      "op": "remove-entity",
      "fields": [
        "id"
      ],
      "summary": "Delete an entity and its whole subtree."
    },
    {
      "op": "reparent",
      "fields": [
        "id",
        "parent"
      ],
      "summary": "Move an entity under a new parent (null = scene root); may not create a cycle."
    },
    {
      "op": "rename",
      "fields": [
        "id",
        "name"
      ],
      "summary": "Set an entity's display name (must be non-empty)."
    },
    {
      "op": "set-tags",
      "fields": [
        "id",
        "tags"
      ],
      "summary": "Replace an entity's tag list."
    },
    {
      "op": "set-component",
      "fields": [
        "id",
        "component",
        "data"
      ],
      "summary": "Add or replace a component; data is validated against that component's schema."
    },
    {
      "op": "remove-component",
      "fields": [
        "id",
        "component"
      ],
      "summary": "Remove a component from an entity."
    }
  ],
  "components": {
    "transform": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "position": {
          "default": [
            0,
            0,
            0
          ],
          "type": "array",
          "prefixItems": [
            {
              "type": "number"
            },
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ]
        },
        "rotation": {
          "default": [
            0,
            0,
            0,
            1
          ],
          "type": "array",
          "prefixItems": [
            {
              "type": "number"
            },
            {
              "type": "number"
            },
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ]
        },
        "scale": {
          "default": [
            1,
            1,
            1
          ],
          "type": "array",
          "prefixItems": [
            {
              "type": "number"
            },
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ]
        }
      }
    },
    "mesh": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "source": {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "primitive"
                },
                "shape": {
                  "type": "string",
                  "enum": [
                    "box",
                    "sphere",
                    "plane",
                    "cylinder",
                    "capsule",
                    "cone",
                    "torus",
                    "wedge"
                  ]
                },
                "size": {
                  "default": [
                    1,
                    1,
                    1
                  ],
                  "type": "array",
                  "prefixItems": [
                    {
                      "type": "number"
                    },
                    {
                      "type": "number"
                    },
                    {
                      "type": "number"
                    }
                  ]
                }
              },
              "required": [
                "kind",
                "shape"
              ]
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "asset"
                },
                "assetId": {
                  "type": "string",
                  "minLength": 1
                },
                "node": {
                  "type": "string"
                }
              },
              "required": [
                "kind",
                "assetId"
              ]
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "polygon"
                },
                "points": {
                  "minItems": 3,
                  "type": "array",
                  "items": {
                    "type": "array",
                    "prefixItems": [
                      {
                        "type": "number"
                      },
                      {
                        "type": "number"
                      }
                    ]
                  }
                },
                "height": {
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "bevel": {
                  "type": "object",
                  "properties": {
                    "size": {
                      "type": "number",
                      "minimum": 0
                    },
                    "segments": {
                      "default": 2,
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 8
                    }
                  },
                  "required": [
                    "size"
                  ]
                }
              },
              "required": [
                "kind",
                "points",
                "height"
              ]
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "heightmap"
                },
                "terrainAsset": {
                  "type": "string",
                  "minLength": 1
                },
                "size": {
                  "default": [
                    80,
                    80
                  ],
                  "type": "array",
                  "prefixItems": [
                    {
                      "type": "number",
                      "exclusiveMinimum": 0
                    },
                    {
                      "type": "number",
                      "exclusiveMinimum": 0
                    }
                  ]
                },
                "amplitude": {
                  "default": 1.5,
                  "type": "number",
                  "minimum": 0
                },
                "frequency": {
                  "default": 0.08,
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "seed": {
                  "default": 1,
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                },
                "offset": {
                  "default": [
                    0,
                    0
                  ],
                  "type": "array",
                  "prefixItems": [
                    {
                      "type": "number"
                    },
                    {
                      "type": "number"
                    }
                  ]
                },
                "resolution": {
                  "default": 96,
                  "type": "integer",
                  "minimum": 8,
                  "maximum": 256
                },
                "flatRadius": {
                  "default": 0,
                  "type": "number",
                  "minimum": 0
                },
                "flatFalloff": {
                  "default": 8,
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "river": {
                  "type": "object",
                  "properties": {
                    "centerX": {
                      "type": "number"
                    },
                    "width": {
                      "type": "number",
                      "exclusiveMinimum": 0
                    },
                    "depth": {
                      "type": "number",
                      "exclusiveMinimum": 0
                    }
                  },
                  "required": [
                    "centerX",
                    "width",
                    "depth"
                  ]
                }
              },
              "required": [
                "kind"
              ]
            }
          ]
        },
        "material": {
          "description": "Material asset GUID (assets/materials/); omitted = engine default material.",
          "type": "string"
        },
        "castShadow": {
          "default": true,
          "type": "boolean"
        },
        "receiveShadow": {
          "default": true,
          "type": "boolean"
        },
        "renderMode": {
          "default": "auto",
          "description": "\"instanced\" collapses all users of the same prefab into one InstancedMesh.",
          "type": "string",
          "enum": [
            "auto",
            "instanced"
          ]
        },
        "lod": {
          "default": true,
          "description": "instanced only: swap to a cheap distance proxy when far from camera. Turn off for props already too small/cheap to benefit (grass, small clutter) — the proxy swap only hurts those visually.",
          "type": "boolean"
        },
        "static": {
          "default": false,
          "description": "Marks geometry static: eligible for HLOD/batch merge into distant proxies. No effect on gameplay; set it for scenery, not for anything a script moves.",
          "type": "boolean"
        }
      },
      "required": [
        "source"
      ]
    },
    "light": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "directional",
            "point",
            "spot",
            "ambient"
          ]
        },
        "color": {
          "default": "#ffffff",
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        "intensity": {
          "default": 1,
          "type": "number",
          "minimum": 0
        },
        "range": {
          "default": 10,
          "type": "number",
          "minimum": 0
        },
        "angle": {
          "default": 0.5235987755982988,
          "type": "number",
          "minimum": 0,
          "maximum": 1.5707963267948966
        },
        "castShadow": {
          "default": false,
          "type": "boolean"
        }
      },
      "required": [
        "kind"
      ]
    },
    "camera": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "fov": {
          "default": 60,
          "type": "number",
          "minimum": 1,
          "maximum": 179
        },
        "near": {
          "default": 0.1,
          "type": "number",
          "exclusiveMinimum": 0
        },
        "far": {
          "default": 1000,
          "type": "number",
          "exclusiveMinimum": 0
        },
        "active": {
          "default": false,
          "description": "Marks this the active camera. Exactly one camera should be active; the render layer enforces first-wins.",
          "type": "boolean"
        },
        "rig": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "follow",
                "chase"
              ]
            },
            "targetTag": {
              "default": "player",
              "type": "string"
            },
            "distance": {
              "default": 7,
              "type": "number",
              "exclusiveMinimum": 0
            },
            "height": {
              "default": 3.5,
              "type": "number"
            },
            "damping": {
              "default": 5,
              "type": "number",
              "exclusiveMinimum": 0
            }
          },
          "required": [
            "mode"
          ]
        }
      }
    },
    "prefab": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "prefabId": {
          "type": "string",
          "minLength": 1
        },
        "props": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {}
        },
        "overrides": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "value": {}
            },
            "required": [
              "path",
              "value"
            ]
          }
        }
      },
      "required": [
        "prefabId"
      ]
    },
    "script": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Registered behavior name (built-ins + assets/scripts/); GET /__hitreg/spec `scripts` lists them and their params."
        },
        "params": {
          "default": {},
          "description": "Per-instance tuning for the behavior's declared params.",
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {}
        }
      },
      "required": [
        "name"
      ]
    },
    "animator": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "play": {
          "type": "string"
        },
        "fade": {
          "default": 0.3,
          "type": "number",
          "minimum": 0
        },
        "speed": {
          "default": 1,
          "type": "number"
        }
      }
    },
    "audio": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "src": {
          "type": "string",
          "minLength": 1
        },
        "volume": {
          "default": 1,
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "loop": {
          "default": false,
          "type": "boolean"
        },
        "autoplay": {
          "default": false,
          "type": "boolean"
        },
        "positional": {
          "default": true,
          "type": "boolean"
        },
        "refDistance": {
          "default": 8,
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "required": [
        "src"
      ]
    },
    "sky": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "top": {
          "default": "#39598f",
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        "bottom": {
          "default": "#101522",
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        "texture": {
          "type": "string"
        },
        "cubemap": {
          "type": "object",
          "properties": {
            "px": {
              "type": "string"
            },
            "nx": {
              "type": "string"
            },
            "py": {
              "type": "string"
            },
            "ny": {
              "type": "string"
            },
            "pz": {
              "type": "string"
            },
            "nz": {
              "type": "string"
            }
          },
          "required": [
            "px",
            "nx",
            "py",
            "ny",
            "pz",
            "nz"
          ]
        },
        "light": {
          "default": 0.5,
          "type": "number",
          "minimum": 0
        },
        "fog": {
          "type": "object",
          "properties": {
            "color": {
              "default": "#101522",
              "type": "string",
              "pattern": "^#[0-9a-fA-F]{6}$"
            },
            "near": {
              "default": 40,
              "type": "number",
              "exclusiveMinimum": 0
            },
            "far": {
              "default": 180,
              "type": "number",
              "exclusiveMinimum": 0
            }
          }
        },
        "sun": {
          "type": "object",
          "properties": {
            "direction": {
              "default": [
                0.4,
                0.55,
                0.3
              ],
              "type": "array",
              "prefixItems": [
                {
                  "type": "number"
                },
                {
                  "type": "number"
                },
                {
                  "type": "number"
                }
              ]
            },
            "color": {
              "default": "#fff6df",
              "type": "string",
              "pattern": "^#[0-9a-fA-F]{6}$"
            },
            "size": {
              "default": 0.997,
              "description": "Closer to 1 = a smaller, sharper glow.",
              "type": "number",
              "minimum": 0.9,
              "maximum": 0.9999
            },
            "intensity": {
              "default": 1.5,
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "postfx": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "bloom": {
          "default": {},
          "type": "object",
          "properties": {
            "enabled": {
              "default": false,
              "type": "boolean"
            },
            "strength": {
              "default": 0.5,
              "type": "number",
              "minimum": 0,
              "maximum": 3
            },
            "radius": {
              "default": 0.4,
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "threshold": {
              "default": 0.85,
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "particles": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "emitting": {
          "default": true,
          "type": "boolean"
        },
        "rate": {
          "default": 20,
          "type": "number",
          "minimum": 0
        },
        "max": {
          "default": 200,
          "type": "integer",
          "minimum": 1,
          "maximum": 2000
        },
        "lifetime": {
          "default": [
            0.8,
            1.6
          ],
          "type": "array",
          "prefixItems": [
            {
              "type": "number",
              "minimum": 0
            },
            {
              "type": "number",
              "minimum": 0
            }
          ]
        },
        "shape": {
          "default": "point",
          "type": "string",
          "enum": [
            "point",
            "sphere",
            "box",
            "cone"
          ]
        },
        "shapeSize": {
          "default": [
            0.2,
            0.2,
            0.2
          ],
          "type": "array",
          "prefixItems": [
            {
              "type": "number"
            },
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ]
        },
        "coneAngle": {
          "default": 25,
          "type": "number",
          "minimum": 0,
          "maximum": 90
        },
        "direction": {
          "default": [
            0,
            1,
            0
          ],
          "type": "array",
          "prefixItems": [
            {
              "type": "number"
            },
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ]
        },
        "speed": {
          "default": [
            1,
            2
          ],
          "type": "array",
          "prefixItems": [
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ]
        },
        "gravity": {
          "default": 0,
          "type": "number"
        },
        "drag": {
          "default": 0,
          "type": "number",
          "minimum": 0
        },
        "sizeStart": {
          "default": 0.15,
          "type": "number",
          "minimum": 0
        },
        "sizeEnd": {
          "default": 0.02,
          "type": "number",
          "minimum": 0
        },
        "spin": {
          "default": 0,
          "type": "number"
        },
        "colorStart": {
          "default": "#ffffff",
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        "colorEnd": {
          "default": "#ffffff",
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        "opacityStart": {
          "default": 1,
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "opacityEnd": {
          "default": 0,
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "blending": {
          "default": "additive",
          "type": "string",
          "enum": [
            "normal",
            "additive"
          ]
        },
        "texture": {
          "type": "string"
        },
        "space": {
          "default": "world",
          "description": "world = particles trail behind a moving emitter; local = they ride it.",
          "type": "string",
          "enum": [
            "local",
            "world"
          ]
        }
      }
    },
    "billboard": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "kind": {
          "default": "bar",
          "type": "string",
          "enum": [
            "bar",
            "text",
            "sprite"
          ]
        },
        "offset": {
          "default": [
            0,
            1.4,
            0
          ],
          "type": "array",
          "prefixItems": [
            {
              "type": "number"
            },
            {
              "type": "number"
            },
            {
              "type": "number"
            }
          ]
        },
        "size": {
          "default": [
            1,
            0.14
          ],
          "type": "array",
          "prefixItems": [
            {
              "type": "number",
              "exclusiveMinimum": 0
            },
            {
              "type": "number",
              "exclusiveMinimum": 0
            }
          ]
        },
        "fill": {
          "default": 1,
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "color": {
          "default": "#4ade80",
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        "background": {
          "default": "#101522",
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}$"
        },
        "backgroundOpacity": {
          "default": 0.65,
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "text": {
          "default": "",
          "type": "string"
        },
        "texture": {
          "type": "string"
        },
        "sheet": {
          "type": "string"
        },
        "frame": {
          "type": "string"
        },
        "visible": {
          "default": true,
          "type": "boolean"
        }
      }
    },
    "netObject": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "authority": {
          "default": "host",
          "description": "host = the session authority simulates it. \"owner\" is RESERVED (ownership wiring lands later) — use \"host\".",
          "type": "string",
          "enum": [
            "host",
            "owner"
          ]
        },
        "sync": {
          "default": {},
          "type": "object",
          "properties": {
            "transform": {
              "default": true,
              "type": "boolean"
            },
            "animation": {
              "default": true,
              "type": "boolean"
            }
          }
        },
        "relevancy": {
          "default": "always",
          "description": "\"proximity\" transmits only to peers within `radius` (interest management, with leave hysteresis).",
          "type": "string",
          "enum": [
            "always",
            "proximity"
          ]
        },
        "radius": {
          "default": 50,
          "description": "Proximity relevancy range in world units.",
          "type": "number",
          "exclusiveMinimum": 0
        },
        "sendEvery": {
          "default": 1,
          "description": "Transmit on every Nth snapshot (staggered per entity); raise for ambient/distant things.",
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        }
      }
    },
    "rigidbody": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "kind": {
          "default": "dynamic",
          "description": "dynamic = physics-driven; kinematic = script-driven, pushes others; static = immovable. A collider with NO rigidbody is already static scenery.",
          "type": "string",
          "enum": [
            "dynamic",
            "kinematic",
            "static"
          ]
        },
        "mass": {
          "default": 0,
          "type": "number",
          "minimum": 0
        },
        "linearDamping": {
          "default": 0,
          "type": "number",
          "minimum": 0
        },
        "angularDamping": {
          "default": 0.05,
          "type": "number",
          "minimum": 0
        },
        "gravityScale": {
          "default": 1,
          "type": "number"
        },
        "ccd": {
          "default": false,
          "type": "boolean"
        },
        "lockRotations": {
          "default": false,
          "type": "boolean"
        }
      }
    },
    "collider": {
