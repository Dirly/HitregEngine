    "chunkStreamer": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1,
          "description": "World folder under assets/chunks/ holding the <cx>_<cz>.chunk.json cells (positions local to the cell; cell world origin = [cx*cellSize,0,cz*cellSize])."
        },
        "cellSize": {
          "default": 16,
          "description": "World-units width of one square chunk cell.",
          "type": "number",
          "exclusiveMinimum": 0
        },
        "radius": {
          "default": 2,
          "description": "Legacy binary residency: load cells within this many cells of the focus. Ignored when `rings` is set.",
          "type": "number",
          "minimum": 1,
          "maximum": 16
        },
        "keepPadding": {
          "default": 1,
          "description": "Extra cells beyond a boundary to hold before downgrading/unloading (hysteresis — stops boundary thrashing).",
          "type": "number",
          "minimum": 0,
          "maximum": 8
        },
        "rings": {
          "description": "Distance LOD rings in CELLS from the focus. Keep `simulation` >= your play area or NPCs in outer cells freeze. Omit for legacy binary `radius` behavior.",
          "type": "object",
          "properties": {
            "simulation": {
              "default": 2,
              "description": "Cells within this radius render + simulate (physics + scripts).",
              "type": "number",
              "minimum": 0
            },
            "fullRender": {
              "default": 3,
              "description": "Out to here: full meshes, no physics/scripts.",
              "type": "number",
              "minimum": 0
            },
            "hlod": {
              "default": 10,
              "description": "Out to here: cheap merged proxy (one draw call per material).",
              "type": "number",
              "minimum": 0
            },
            "farTerrain": {
              "default": 32,
              "description": "Out to here: coarse far proxy. Beyond: unloaded.",
              "type": "number",
              "minimum": 0
            }
          }
        }
      },
      "required": [
        "source"
      ]
    },
    "subscene": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "properties": {
        "scene": {
          "type": "string",
          "minLength": 1,
